# Global environment configuration for ChartScanAI
# Copy this file to .env.development or .env.production and fill in your values

# ==================== GENERAL ====================
NODE_ENV=development
APP_NAME=ChartScanAI
APP_VERSION=0.1.0

# ==================== API SERVER ====================
API_PORT=3000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:3000
LOG_LEVEL=debug

# ==================== WEBSOCKET SERVER ====================
WS_PORT=3001
WS_HOST=0.0.0.0
WS_BASE_URL=http://localhost:3001

# ==================== FRONTEND ====================
VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3001
VITE_APP_NAME=ChartScanAI

# ==================== DATABASE ====================
# PostgreSQL Configuration
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chartscanai
DB_USER=postgres
DB_PASSWORD=postgres
DB_CONNECTION_POOL_MIN=2
DB_CONNECTION_POOL_MAX=10

# OR use SQLite (for local development)
# DB_TYPE=sqlite
# DB_PATH=./data/chartscanai.db

# ==================== REDIS CACHE ====================
# Local Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OR use Upstash Redis (Cloud)
# REDIS_URL=redis://:password@host:port

# Cache TTL in seconds
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# ==================== BROKER API KEYS ====================
# You'll manage these in config/api-keys.json for security
# These are just indicators

GROW_ENABLED=true
UPSTOX_ENABLED=true
TICKER_TAPE_ENABLED=true

# ==================== PATTERN DETECTION ====================
# Minimum confidence score (0-1) for pattern alerts
MIN_PATTERN_CONFIDENCE=0.75

# Number of candles to analyze
CANDLE_HISTORY_SIZE=100

# Update interval in milliseconds
DATA_UPDATE_INTERVAL=5000

# ==================== ALERTS & NOTIFICATIONS ====================
# Email notifications (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@chartscanai.com

# SMS notifications (Twilio) - Optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ==================== SCREEN READER ====================
# For Ticker Tape and other screen-based data
SCREEN_READER_ENABLED=false
SCREEN_READER_FPS=2
SCREEN_READER_TIMEOUT=30000

# ==================== MONITORING & LOGGING ====================
# Datadog
DATADOG_ENABLED=false
DATADOG_API_KEY=

# Error tracking (Sentry)
SENTRY_DSN=

# ==================== CORS & SECURITY ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ==================== FEATURE FLAGS ====================
FEATURE_BACKTEST=true
FEATURE_LIVE_SCREEN_READER=false
FEATURE_MACHINE_LEARNING=false
FEATURE_ADVANCED_ANALYTICS=true

