{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env*", "**/tsconfig*.json"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "dev": {
      "cache": false,
      "interactive": true,
      "persistent": true
    },
    "build": {
      "outputs": ["dist/**", "build/**"],
      "cache": true,
      "dependsOn": ["^build"]
    },
    "test": {
      "outputs": ["coverage/**"],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "lint:fix": {
      "cache": false
    },
    "type-check": {
      "cache": true
    },
    "migrate": {
      "cache": false
    }
  }
}
