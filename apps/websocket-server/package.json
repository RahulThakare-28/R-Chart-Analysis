{
  "name": "@chartscanai/websocket",
  "version": "0.1.0",
  "description": "WebSocket server for real-time updates in ChartScanAI",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node src/main.ts",
    "dev:watch": "nodemon --exec ts-node src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chartscanai/config": "*",
    "@chartscanai/core": "*",
    "@chartscanai/shared": "*",
    "dotenv": "^16.3.1",
    "redis": "^4.6.13",
    "socket.io": "^4.7.2",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
